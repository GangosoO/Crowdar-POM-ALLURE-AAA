{
  "name": "crowdar",
  "version": "1.0.0",
  "description": "E2E Crowdar",
  "main": "index.js",
  "scripts": {
    "clean": "rimraf ./allure-results",
    "test": "cypress open --browser chrome --e2e",
    "test-all": "cypress run --spec 'cypress/e2e/**/*.cy.js' --browser chrome --headed --env allure=true",
    "test-Login": "cypress run --spec 'cypress/e2e/UI/Inicio_de_sesión.cy.js' --browser chrome --headed --env allure=true",
    "test-Carrito": "cypress run --spec 'cypress/e2e/UI/Carrito_de_compras.cy.js' --browser firefox --headed --env allure=true",
    "allure:report": "allure generate allure-results --clean -o allure-report && allure open allure-report",
    "test-api": "cypress run --spec 'cypress/e2e/api/sauceDemo.cy.js' --browser chrome --headed --env allure=true",
    "test-smoke": "cypress run --spec 'cypress/e2e/Smoke_Regression/Smoke.cy.js' --browser chrome --headed --env allure=true",
    "test-regression": "cypress run --spec 'cypress/e2e/Smoke_Regression/Regression.cy.js' --browser chrome --headed --env allure=true"
  },
  "keywords": [
    "E2E",
    "Crowdar",
    "Framerwork",
    "Cypress"
  ],
  "author": "Kendell Rodriguez",
  "license": "ISC",
  "devDependencies": {
    "@shelex/cypress-allure-plugin": "^2.41.2",
    "cypress": "^15.11.0",
    "cypress-mochawesome-reporter": "^4.0.2",
    "rimraf": "^6.1.3"
  }
}
